def genera_numeri():       
    """Chiede un numero intero positivo"""
    numero=int(input('Dammi un numero intero positivo:  '))
    if numero > 0:
        risultato=is_pari(numero)
        return risultato, numero
    else:
        risultato=genera_numeri()
        return risultato

result, numero = genera_numeri()
print(result)

def crea_lista(n, lista):
    lista.append(n)
    if n==1 or len(lista)==100:
        return lista
    else:
        if is_pari(n)==True:
            n=n//2
            return crea_lista(n, lista)
        else:
            n=(n*3)+1
            return crea_lista(n, lista)

lista_finale = crea_lista(numero, [])
print(lista_finale)

def analizza_sequenza(n):
    massimo=max(n)
    somma=sum(n)
    lunghezza=len(n)
    return massimo, somma, lunghezza

massimo, somma, lunghezza=analizza_sequenza(lista_finale)
print('Il valore massimo della lista è:', massimo)
print('La somma dei valori nella lista è:' , somma)
print('La sua lunghezza è:' , lunghezza)

def ricerca_lista(n):
    multipli=[]
    for x in n:
        if x%5 == 0:
            multipli.append(x)
    if multipli==[]:
        return 'Non ci sono multipli di 5'
    else:
        return multipli

ricerca=ricerca_lista(lista_finale)
print ('I multipli di 5 sono', ricerca)