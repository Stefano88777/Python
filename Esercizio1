def crea_lista(n, lista):
    lista.append(n)
    if n==1 or len(lista)==100:
        return lista
    else:
        if is_pari(n)==True:
            n=n//2
            return crea_lista(n, lista)
        else:
            n=(n*3)+1
            return crea_lista(n, lista)

lista_finale = crea_lista(numero, [])
