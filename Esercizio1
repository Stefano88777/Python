def genera_numeri():       
    """Chiede un numero intero positivo"""
    numero=int(input('Dammi un numero intero positivo:  '))
    if numero > 0:
        risultato=is_pari(numero)
        return risultato, numero
    else:
        risultato=genera_numeri()
        return risultato

result, numero = genera_numeri()
